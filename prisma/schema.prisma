generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum STATUS {
  PREMIUM
  REFUNDED
  PAYMENT_FAILED
  FREE_PLAN
}

enum USERROLE {
  ADMIN
  USER
}

model Account {
  id                       String   @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? // @db.Text
  access_token             String? // @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? // @db.Text
  session_state            String?
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refresh_token_expires_in Int?
  createdAt                DateTime @default(now())

  @@unique([provider, providerAccountId])
}

model User {
  id            String    @id @default(cuid())
  uuid          Int       @default(autoincrement())
  name          String
  bio           String?
  role          USERROLE  @default(USER)
  email         String    @unique
  password      String?
  emailVerified DateTime?
  joinedAt      DateTime? @default(now())
  image         String?
  imageKey      String?

  username          String?   @unique @db.VarChar(20)
  usernameChangedAt DateTime?

  apiToken String? @unique

  // Subscription
  customerId       String?   @unique
  subscriptionId   String?
  variantId        Int?
  currentPeriodEnd DateTime?
  planStatus       STATUS    @default(FREE_PLAN)
  accounts         Account[]

  socials    Socials[]
  collection Collection[]
  links      Link[]
}

model Socials {
  id       String  @id @default(cuid())
  type     String
  handle   String?
  url      String?
  position Int     @default(0)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
}

model Collection {
  id        String   @id @default(cuid())
  userId    String
  title     String
  position  Int      @default(0)
  type      String   @default("collection")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  links Link[]

  @@index([userId, position])
}

model Link {
  id           String  @id @default(cuid())
  userId       String
  collectionId String?
  title        String
  url          String?
  isActive     Boolean @default(true)

  position           Int?
  collectionPosition Int?

  thumbnail String?
  icon      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection Collection? @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([userId, position])
  @@index([collectionId, collectionPosition])
}

model Waitlist {
  id     String   @id @default(cuid())
  email  String   @unique
  signed DateTime @default(now())
}

model VerificationToken {
  id      String   @id @default(cuid())
  token   String   @unique
  email   String   @unique
  expires DateTime
}

model ResetPasswordToken {
  id      String   @id @default(cuid())
  token   String   @unique
  email   String   @unique
  expires DateTime
}
